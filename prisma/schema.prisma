generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["darwin-arm64", "darwin", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BanRequest {
  id          String   @id
  author_id   String
  target_id   String
  guild_id    String
  reason      String
  created_at  DateTime @default(now())
  status      Int      @default(1)
  reviewer_id String?

  @@index([status, guild_id])
  @@index([target_id, guild_id, status])
}

model MuteRequest {
  id          String   @id
  author_id   String
  target_id   String
  guild_id    String
  reason      String
  created_at  DateTime @default(now())
  status      Int      @default(1)
  duration    Int
  reviewer_id String?

  @@index([status, guild_id])
  @@index([target_id, guild_id, status])
}

model Message {
  id           String   @id
  author_id    String
  channel_id   String
  guild_id     String
  created_at   DateTime
  deleted      Boolean  @default(false)
  content      String?
  sticker_id   String?
  /// ID of the message this message is replying to
  reference_id String?

  /// Index for counting a user's messages
  @@index([author_id, guild_id])
  /// Index for deleteMessagesByUser queries
  @@index([author_id, channel_id, deleted])
  /// Index for TTL-based message deletion
  @@index([created_at])
}

model Infraction {
  id                Int       @id @default(autoincrement())
  action            Int
  flag              Int       @default(0)
  guild_id          String
  executor_id       String
  target_id         String
  created_at        DateTime  @default(now())
  reason            String?
  request_author_id String?
  expires_at        DateTime?
  updated_at        DateTime?
  updated_by        String?
  archived_at       DateTime?
  archived_by       String?

  /// Index for counting/searching a user's infractions with a filter
  /// Also covers (target_id, guild_id) prefix queries
  @@index([target_id, guild_id, action, archived_at, archived_by])
  /// Index for active infractions listing
  @@index([expires_at, archived_at, archived_by])
  /// Index for moderation activity queries by executor
  @@index([executor_id, guild_id])
  /// Index for finding latest ban/mute by action + target
  @@index([action, target_id, guild_id, archived_at, archived_by])
}

model MessageReport {
  /// ID of the report message
  id              String   @id
  /// ID of the message that was reported
  message_id      String   @unique
  /// Channel where the message was sent
  channel_id      String
  /// Guild where the message was sent
  guild_id        String
  /// Author of the reported message
  author_id       String
  /// Author of the report
  reported_by     String
  /// Where the report was created
  created_at      DateTime @default(now())
  /// Status of the report
  status          Int      @default(4)
  /// Additional report context
  flags           Int
  /// Whether the message was deleted
  message_deleted Boolean  @default(false)
  /// ID of the user that resolved the report
  resolved_by     String?
  /// Content of the reported message
  content         String?

  @@index([status, guild_id])
  @@index([author_id, status, guild_id])
  /// Index for ban-triggered report cleanup
  @@index([author_id, status, message_deleted, guild_id])
  /// Index for TTL-based report removal
  @@index([created_at, status, guild_id])
}

model UserReport {
  id          String   @id
  target_id   String
  guild_id    String
  reported_by String
  created_at  DateTime @default(now())
  status      Int      @default(2)
  reason      String
  /// ID of the user that resolved the report
  resolved_by String?

  @@index([status, guild_id])
  /// Index for ban-triggered report cleanup
  @@index([target_id, status])
  /// Index for TTL-based report removal
  @@index([created_at, status, guild_id])
}

model TemporaryRole {
  member_id  String
  role_id    String
  guild_id   String
  expires_at DateTime

  @@id([member_id, role_id, guild_id])
  @@index([expires_at])
}

model TemporaryMessage {
  message_id String
  channel_id String
  expires_at DateTime

  @@id([message_id, channel_id])
  @@index([expires_at])
}

model Reminder {
  id         String   @id @default(uuid())
  author_id  String
  channel_id String
  reminder   String
  created_at DateTime @default(now())
  expires_at DateTime

  @@index([author_id])
  @@index([expires_at])
}

model PermissionOverwrites {
  guild_id   String @id
  /// Stringified JSON object of the permission overwrites
  overwrites String
}

model Highlight {
  user_id         String
  guild_id        String
  patterns        HighlightPattern[]
  channel_scoping HighlightChannelScoping[]

  @@id([user_id, guild_id])
  /// Index for guild-scoped highlight queries (hot path on every message)
  @@index([guild_id])
}

model HighlightPattern {
  user_id   String
  guild_id  String
  pattern   String
  highlight Highlight @relation(fields: [user_id, guild_id], references: [user_id, guild_id], onDelete: Cascade)

  @@id([user_id, guild_id, pattern])
}

model HighlightChannelScoping {
  user_id    String
  guild_id   String
  channel_id String
  /// Whitelist [`0`] or Blacklist [`1`]
  type       Int
  highlight  Highlight @relation(fields: [user_id, guild_id], references: [user_id, guild_id], onDelete: Cascade)

  @@id([user_id, guild_id, channel_id])
}
